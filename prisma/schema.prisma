generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  wallet    String   @id
  name      String
  createdAt DateTime @default(now())
}

model Quiz {
  id        String   @id @default(uuid())
  slug      String   @unique
  title     String
  badge     String   @default("퀴즈 과제")
  track     String   @default("")
  markdown  String
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Lecture {
  id        String   @id @default(uuid())
  slug      String   @unique
  title     String
  badge     String   @default("학습자료")
  track     String   @default("")
  /** 트랙 안에서의 정렬 순서 (회차) */
  order     Int      @default(0)
  /** markdown: 섹션형 강의록, html: 인터랙티브 자료 (원문 전체를 content에 저장) */
  format    String   @default("markdown")
  markdown  String
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model QuizResponse {
  id        String   @id @default(uuid())
  quizId    String
  wallet    String
  name      String
  answers   String
  score     Int      @default(0)
  total     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([quizId, wallet])
}

model Comment {
  id            String    @id @default(uuid())
  quizId        String
  /** 어느 문항의 토론인지 (문항 인덱스) */
  questionIndex Int
  /** 작성자 지갑 = 공개 식별자 (이름은 여기 저장하지 않는다) */
  wallet        String
  body          String
  /** 퀴즈 답 제출로 생성된 최상위 글인지 (true) vs 일반 대댓글/토론(false) */
  isSubmission  Boolean   @default(false)
  /** null이면 최상위 글, 값이 있으면 대댓글 */
  parentId      String?
  parent        Comment?  @relation("Thread", fields: [parentId], references: [id], onDelete: Cascade)
  replies       Comment[] @relation("Thread")
  /** 소프트 삭제 — 모더레이션/본인 삭제 시 "삭제된 글" 처리 */
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([quizId, questionIndex])
}

model PushSubscription {
  id        String   @id @default(uuid())
  wallet    String
  /** 브라우저 푸시 엔드포인트 (기기·브라우저마다 다르다) */
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([wallet])
}

model Submission {
  id        String   @id @default(uuid())
  wallet    String
  name      String
  track     String   @default("cryptozombies")
  week      String
  zombieUrl String
  note      String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([wallet, track, week])
}

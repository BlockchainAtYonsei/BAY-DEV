generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  wallet    String   @id
  name      String
  createdAt DateTime @default(now())
}

model Submission {
  id        String   @id @default(uuid())
  wallet    String
  name      String
  track     String   @default("cryptozombies")
  week      String
  zombieUrl String
  note      String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([wallet, track, week])
}
